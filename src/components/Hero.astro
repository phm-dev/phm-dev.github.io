    viewOnGitHub: 'Zobacz na GitHub',
    terminal: 'terminal',
    whatIsTitle: 'Czym jest PHM',
    precompiledTitle: 'Prekompilowane PHP',
    precompiledLine1: 'Zbudowane raz',
    precompiledLine2: 'Instalowane natychmiast',
    macosTitle: 'Tylko macOS',
    macosLine1: 'Zaprojektowane specjalnie dla macOS',
    macosLine2: 'Bez kompromisów wieloplatformowych',
    noBuildTitle: 'Bez narzędzi budowania',
    noBuildLine1: 'Bez Homebrew',
    noBuildLine2: 'Bez MacPorts',
    noBuildLine3: 'Bez lokalnej kompilacji',
    deterministicTitle: 'Deterministyczne i czyste',
    deterministicLine1: 'Bez konfliktów wersji',
    deterministicLine2: 'Natywne dla Twojego Maca',
